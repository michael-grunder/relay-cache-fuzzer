#!/usr/bin/env php
<?php

declare(strict_types=1);

use MichaelGrunder\RelayCacheFuzzer\Config;
use MichaelGrunder\RelayCacheFuzzer\Fuzzer;
use MichaelGrunder\RelayCacheFuzzer\FuzzerException;
use MichaelGrunder\RelayCacheFuzzer\ReplayRunner;
use MichaelGrunder\RelayCacheFuzzer\SequentialFuzzer;
use MichaelGrunder\RelayCacheFuzzer\SimpleSequentialFuzzer;

require dirname(__DIR__) . '/vendor/autoload.php';
require dirname(__DIR__) . '/src/Fuzzer.php';

try {
    $config = Config::fromArgv($argv);

    if ($config->replayFile !== null) {
        $runner = new ReplayRunner($config);
        $runner->run();
    } elseif ($config->mode === 'simple-sequential') {
        $fuzzer = new SimpleSequentialFuzzer($config);
        $fuzzer->run();
    } elseif ($config->mode === 'sequential') {
        $fuzzer = new SequentialFuzzer($config);
        $fuzzer->run();
    } else {
        $fuzzer = new Fuzzer($config);
        $fuzzer->run();
    }
} catch (Throwable $e) {
    fwrite(STDERR, $e->getMessage() . PHP_EOL);
    exit($e instanceof FuzzerException && str_contains($e->getMessage(), 'reproducer=') ? 2 : 1);
}
