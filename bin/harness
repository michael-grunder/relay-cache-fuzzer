#!/usr/bin/env php
<?php

declare(strict_types=1);

use MichaelGrunder\RelayCacheFuzzer\Harness\Coordinator;
use MichaelGrunder\RelayCacheFuzzer\Harness\HarnessConfig;
use MichaelGrunder\RelayCacheFuzzer\Harness\HarnessException;

require dirname(__DIR__) . '/vendor/autoload.php';
require dirname(__DIR__) . '/src/Harness.php';

try {
    $config = HarnessConfig::fromArgv($argv);
    (new Coordinator($config))->run();
} catch (HarnessException $e) {
    fwrite(STDERR, $e->getMessage() . PHP_EOL);
    exit(1);
} catch (Throwable $e) {
    fwrite(STDERR, $e->getMessage() . PHP_EOL);
    exit(1);
}
